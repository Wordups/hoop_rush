; Hoop Rush — Godot 4.7 project
; iPhone-first portrait, 60fps, GDScript, painted 2D.

config_version=5

[application]

config/name="Hoop Rush"
run/main_scene="res://scenes/court_3d.tscn"
config/features=PackedStringArray("4.7", "Mobile")

[autoload]

DataManager="*res://scripts/autoloads/data_manager.gd"
SaveManager="*res://scripts/autoloads/save_manager.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"

[input_devices]

pointing/emulate_touch_from_mouse=true

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"

[rendering]

renderer/rendering_method="mobile"
textures/canvas_textures/default_texture_filter=1
